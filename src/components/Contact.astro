---
import ScrollReveal from './ScrollReveal.astro';
---

<section id="contact" class="section-padding bg-gray-50/50 dark:bg-surface-dark-alt/50 transition-colors duration-300">
  <div class="max-w-7xl mx-auto">
    <div class="max-w-3xl mx-auto text-center">
      <ScrollReveal>
        <h2 class="section-title">
          一起 <span class="gradient-text">创造</span>
        </h2>
        <p class="section-subtitle mx-auto">
          我正在寻找实习机会！如果你有合适的岗位或想聊聊合作，
          欢迎随时联系我 👋
        </p>
      </ScrollReveal>

      <ScrollReveal delay={200}>
        <div class="flex flex-col items-center gap-6 mt-12">
          <!-- Email -->
          <a href="mailto:2183147502@qq.com" 
             class="card p-5 w-full max-w-md flex items-center gap-4 hover:border-primary-300 dark:hover:border-primary-700 transition-all duration-300 group">
            <div class="w-12 h-12 rounded-xl bg-primary-50 dark:bg-primary-900/30 flex items-center justify-center 
                        group-hover:scale-110 transition-transform duration-300">
              <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="text-left">
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">邮箱</p>
              <p class="text-base font-semibold text-gray-900 dark:text-gray-100">2183147502@qq.com</p>
            </div>
          </a>

          <!-- Phone -->
          <a href="tel:18236316074" 
             class="card p-5 w-full max-w-md flex items-center gap-4 hover:border-primary-300 dark:hover:border-primary-700 transition-all duration-300 group">
            <div class="w-12 h-12 rounded-xl bg-primary-50 dark:bg-primary-900/30 flex items-center justify-center 
                        group-hover:scale-110 transition-transform duration-300">
              <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div class="text-left">
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">电话</p>
              <p class="text-base font-semibold text-gray-900 dark:text-gray-100">18236316074</p>
            </div>
          </a>

          <!-- Social Links -->
          <div class="flex gap-4">
            <a href="https://github.com" target="_blank" rel="noopener noreferrer"
               class="card p-4 hover:border-primary-300 dark:hover:border-primary-700 transition-all duration-300 group">
              <svg class="w-6 h-6 text-gray-600 dark:text-gray-400 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
            <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer"
               class="card p-4 hover:border-primary-300 dark:hover:border-primary-700 transition-all duration-300 group">
              <svg class="w-6 h-6 text-gray-600 dark:text-gray-400 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            <a href="https://dribbble.com" target="_blank" rel="noopener noreferrer"
               class="card p-4 hover:border-primary-300 dark:hover:border-primary-700 transition-all duration-300 group">
              <svg class="w-6 h-6 text-gray-600 dark:text-gray-400 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 24C5.385 24 0 18.615 0 12S5.385 0 12 0s12 5.385 12 12-5.385 12-12 12zm10.12-10.358c-.35-.11-3.17-.953-6.384-.438 1.34 3.684 1.887 6.684 1.992 7.308 2.868-1.265 4.673-3.613 4.392-6.87zm-6.41 7.047c-.207-.888-1.027-4.053-2.466-7.932-6.208 2.428-8.424 5.71-8.615 5.994C7.442 21.155 9.656 23 12 23c1.214 0 2.36-.336 3.35-.9l.36-.41zm-10.45-3.622c.255-.36 3.105-4.34 8.352-6.39-.17-.39-.352-.78-.55-1.17-3.648-.144-7.858-.18-8.364-.173-.006.356-.008.712-.008 1.07 0 2.24.57 4.34 1.614 6.12l.956.543zm.126-9.173c.506.006 5.104.042 8.45.258 1.04-1.982 1.81-3.458 1.936-3.734-2.23-1.114-4.736-1.502-7.21-1.08-1.33.236-2.57.758-3.636 1.52l.46 3.036zm9.155-2.138c-.204.464-1.002 2.006-2.052 4.042 2.826.705 5.806.564 6.146.54.03-.39.046-.78.046-1.17 0-1.428-.318-2.782-.88-4.006-.856.2-2.033.682-3.26 1.22v.158c-.028-.006-.02-.008 0 .01-.05.174-.09.348-.136.522l-.328.95z"/>
              </svg>
            </a>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={300}>
        <div class="mt-16">
          <a href="/resume.pdf" target="_blank" class="btn-primary text-lg px-8 py-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                    d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            下载简历 PDF
          </a>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
